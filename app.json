{
  "expo": {
    "name": "ChapPlus",
    "slug": "chapplus",
    "version": "1.0.0",
    "scheme": "chapplus",
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": ["expo-router"],
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpg",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.saminyasar004.chapplus",
      "bundleIdentifier": "com.saminyasar004.chapplus"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpg",
        "backgroundColor": "#FFFFFF",
        "width": 1024,
        "height": 1024
      },
      "package": "com.saminyasar004.chapplus",
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ddcc2120-df98-47f1-aaa7-25e86a95394e"
      }
    }
  }
}
